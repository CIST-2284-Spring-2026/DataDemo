<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DataDemo.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label Text="School Database Demo" FontSize="24" />
            <Label Text="Major" />
            <Picker x:Name="pkMajor" />
            <Label Text="Course" />
            <Picker x:Name="pkCourse" />
            <Label Text="Campus" />
            <Picker x:Name="pkCampus" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
