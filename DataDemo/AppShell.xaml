<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DataDemo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DataDemo"    
    xmlns:pages="clr-namespace:DataDemo.Pages"
    Title="DataDemo">
    <TabBar>  
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Campuses"
            ContentTemplate="{DataTemplate pages:CampusPage}" />
        <ShellContent
            Title="Courses"
            ContentTemplate="{DataTemplate pages:CoursePage}" />
        <ShellContent
            Title="Majors"
            ContentTemplate="{DataTemplate pages:MajorPage}" />
    </TabBar>
</Shell>
